{
  "id" : "org.evans.SpaceDodge",
  "runtime" : "org.freedesktop.Platform",
  "runtime-version" : "23.08",
  "sdk" : "org.freedesktop.Sdk",
  "command" : "space-dodge",
  "modules" : [
    {
      "name" : "python3-pygame",
      "buildsystem" : "simple",
      "sources" : [
        {
          "url" : "https://files.pythonhosted.org/packages/source/p/pygame/pygame-2.5.2.tar.gz",
          "sha256" : "c1b89eb5d539e7ac5cf75513125fb5f2f0a2d918b1fd6e981f23bf0ac1b1c24a",
          "type" : "archive"
        }
      ],
      "build-commands" : [
        "pip3 install --no-index --prefix=/app ."
      ]
    },
    {
      "name" : "space-dodge",
      "buildsystem" : "simple",
      "sources" : [
        {
          "path" : ".",
          "type" : "dir"
        }
      ],
      "build-commands" : [
        "install -Dm755 space-dodge /app/bin/space-dodge",
        "install -Dm644 games_final.py /app/games_final.py",
        "install -Dm644 scores.txt /app/scores.txt",
        "mkdir -p /app/assets/backgrounds /app/assets/music",
        "cp -r *.jpg /app/assets/backgrounds/",
        "install -Dm644 main.png /app/main.png",
        "cp -r *.mp3 /app/assets/music/",
        "install -Dm644 org.evans.SpaceDodge.desktop /app/share/applications/org.evans.SpaceDodge.desktop",
        "install -Dm644 org.evans.SpaceDodge.appdata.xml /app/share/metainfo/org.evans.SpaceDodge.appdata.xml",
        "install -Dm644 org.evans.SpaceDodge.svg /app/share/icons/hicolor/scalable/apps/org.evans.SpaceDodge.svg"
      ]
    }
  ],
  "finish-args" : [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri"
  ],
  "source-date-epoch" : 1771936137
}
